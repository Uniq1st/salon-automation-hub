{
  "name": "salon-automation-hub",
  "version": "1.0.0",
  "description": "AI-powered salon marketing automation + social media engine. Claude AI, image/video generation, Instagram/TikTok posting, SMS/Email campaigns, revenue automation",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "node --watch --env-file=.env backend/server.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src backend tests",
    "start": "node --env-file=.env backend/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "openai": "^4.52.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "twilio": "^6.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
